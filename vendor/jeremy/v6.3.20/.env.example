BDAG_NODE_PEER_ADDRESSES=
BDAG_SYNC_COORDINATOR_FAST_RESTART_COOLDOWN_SECONDS=900
BDAG_SYNC_COORDINATOR_RESTART_ON_STALE_IMPORT=1
BDAG_CATCHUP_PAUSE_ENABLED=1
BDAG_CATCHUP_PAUSE_THRESHOLD_BLOCKS=300
BDAG_CATCHUP_IO_PRESSURE_PAUSE_ENABLED=1
BDAG_CATCHUP_IO_PRESSURE_MIN_LAG_BLOCKS=25
BDAG_CATCHUP_IOWAIT_WARN_PERCENT=15
BDAG_CATCHUP_IO_SOME_AVG10_WARN=20.0
BDAG_CATCHUP_IO_FULL_AVG10_WARN=10.0
BDAG_CATCHUP_NODE_RECREATE_ENABLED=1
BDAG_CATCHUP_NODE_CACHE_MB=1024
BDAG_CATCHUP_NODE_CACHE_MIN_MB=512
BDAG_CATCHUP_NODE_CACHE_MEMORY_PERCENT=15
BDAG_NODE_PEER_LIMIT=8
BDAG_NODE_PEER_STABLE_PORTS=8150,8151,8152,8154
NODE_RPC_USER=test
NODE_RPC_PASS=test
NODE_RPC_URL=http://node:38131

# Extra node flags.
NODE_ARGS_APPEND=
# Production pool deployments are mainnet-only. Install/runtime scripts reject
# any rawdatadir network value other than mainnet.

POSTGRES_USER=bdag_pool
POSTGRES_DB=bdagpool
POSTGRES_PASSWORD=change_me_to_a_strong_secret

# ---------------------------------------------------------------------------
# Mining pool — passed into the `pool` container environment.
# ---------------------------------------------------------------------------
POOL_BIND_ADDR=0.0.0.0:3334
PPLNS_N_WORK=1000
POOL_FEE_PERCENTAGE=1.0
POOL_BLOCK_MATURITY=10
POOL_PAYOUT_MATURITY=4096

# CPU miner (only used when COMPOSE_PROFILES includes "miner").
MINER_POOL_URL=stratum+tcp://pool:3334
MINER_POOL_PASS=x
MINER_WORKERS=1




# Live-tested block-candidate policy from the 2026-06-14 pool efficiency A/B tests.
# Keep local block-candidate expiry strict, but avoid automatic expansion and
# aggressive clean-job resends that amplify stale-template races.
POOL_RPC_ROUTER_NODE_HEALTH_ENABLED=true
POOL_TEMPLATE_TTL_REFRESH_MS=500
POOL_SUBMIT_STALE_BLOCK_CANDIDATES=false
POOL_MAX_BLOCK_CANDIDATE_JOB_AGE_MS=2500
POOL_AUTO_TUNE_BLOCK_CANDIDATE_JOB_AGE=false
POOL_SUBMIT_BLOCK_HEADER_V2_ENABLED=true
POOL_STALE_RACE_REJECT_WINDOW_SECONDS=10
POOL_STALE_RACE_CLIENT_RESEND_THRESHOLD=3
POOL_STALE_RACE_RECOVERY_COOLDOWN_SECONDS=15
POOL_EXPIRED_JOB_CLIENT_RECONNECT_THRESHOLD=3
POOL_EXPIRED_JOB_CLIENT_RECONNECT_WINDOW_SECONDS=120
POOL_EXPIRED_JOB_CLIENT_RECONNECT_COOLDOWN_SECONDS=60
POOL_ALLOW_MULTIPLE_BLOCK_CANDIDATES_PER_JOB=true
POOL_PREEMPTIVE_BLOCK_CANDIDATE_REFRESH_ENABLED=true
