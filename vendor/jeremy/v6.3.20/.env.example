DOCKERFILE=dockerfile
DOCKER_PLATFORM=linux/amd64
# Optional overrides for dockerfile-dev named build contexts.
# BLOCKDAG_CORECHAIN_CONTEXT=../blockdag-corechain
# POOL_SRC_CONTEXT=../pool
# CPU_MINER_SRC_CONTEXT=../cpu-miner
COLLECTOR_SRC_CONTEXT=../collector
DASHBOARD_SRC_CONTEXT=../dashboard2
# Set to 1 to run the node in archival mode (--archival; consensus keeps all
# blocks instead of pruning). Historical bootstrap/repair is IPFS-owned in this
# release path; do not reintroduce runtime chain-artifact download hooks.
BDAG_NODE_ARCHIVAL=0

# Optional compose services:
#   blank -> base stack only
#   miner -> include CPU miner service (requires DOCKERFILE=dockerfile-dev)
# COMPOSE_PROFILES=miner

P2P_PORT=8150
BDAG_RPC_PORT=38131
EVM_HTTP_PORT=18545
EVM_WS_PORT=18546
NODE_METRICS_PORT=6060
POOL_BIND_PORT=3334
POOL_API_PORT=9090
COLLECTOR_HOST_PORT=9280
DASHBOARD_BIND=0.0.0.0
DASHBOARD_HOST_PORT=8088
DASHBOARD_LISTEN=0.0.0.0:8088
# Dashboard UI display timezone.
DASHBOARD_TIMEZONE=Africa/Johannesburg

# NODE_DATA_DIR=./node-data

# Required for any pool/miner deployment. Do not use the zero address.
# POOL_COINBASE_ADDRESS may be set separately when it must differ from the
# displayed miner/pool identity; otherwise set MINING_POOL_ADDRESS only.
MINING_POOL_ADDRESS=0xEd5e2dD1377aBe28907673cdEa8c2c04Fb715dcd
POOL_COINBASE_ADDRESS=

# Storage placement for constrained mining appliances. Release installers keep
# growing node chain data on capacity storage, then move frequent small writes
# such as Postgres and dashboard/runtime state to internal storage when it has
# enough free space.
BDAG_STORAGE_PROFILE=auto
BDAG_CHAIN_DATA_DIR=./data
BDAG_DATA_DIR=./data
BDAG_NODE_DATA_DIR=./data/node
BDAG_POSTGRES_DATA_DIR=./data/postgres
BDAG_RUNTIME_DIR=./ops/runtime
BDAG_STORAGE_MIN_CHAIN_FREE_GIB=50
BDAG_STORAGE_MIN_RUNTIME_FREE_GIB=4

# Ephemeral scratch policy. Small temporary files belong on RAM-backed tmpfs so
# they do not add avoidable writes to the USB chain device. Large chain/IPFS
# restore staging must stay on capacity storage unless explicitly sized.
BDAG_EPHEMERAL_TMPFS_ENABLED=1
BDAG_EPHEMERAL_DIR=/run/bdag-pool
BDAG_HOST_TMPDIR=/run/bdag-pool/tmp
BDAG_CONTAINER_TMPFS_SIZE=128m
BDAG_NODE_TMPFS_SIZE=512m
BDAG_NODE_SHM_SIZE=512m
BDAG_BUILD_TMPDIR=./.build-tmp
BDAG_BUILD_CACHE_WARN_GIB=4
BDAG_ROOT_FREE_WARN_GIB=6
BDAG_ROOT_FREE_FAIL_GIB=2

# Single P2P host port used by Docker publishing, firewall, and local peer
# advertisement.
BDAG_P2P_PROTOCOLS=tcp

# Standard mining-host performance defaults. The release topology has one
# production node with a direct pool-to-node RPC path.
BDAG_NODE_CACHE_MB=2048
BDAG_EVM_CACHE_MB=512
BDAG_NODE_CACHE_DATABASE_PERCENT=70
BDAG_NODE_OBSOLETE_HEIGHT=20
BDAG_BLOCK_READ_AHEAD_KB=1024
BDAG_BLOCK_NR_REQUESTS=256
BDAG_NODE_CPU_SHARES=6144
BDAG_POOL_CPU_SHARES=5120
BDAG_POOL_DB_CPU_SHARES=4096
BDAG_DASHBOARD_CPU_SHARES=128
BDAG_NODE_MEMORY_LOW=768M
BDAG_NODE_MEMORY_HIGH=auto
BDAG_NODE_MEMORY_HIGH_PERCENT=60
BDAG_NODE_MEMORY_HIGH_MIN=3072M
BDAG_POOL_MEMORY_LOW=256M
BDAG_POOL_DB_MEMORY_LOW=512M
BDAG_DASHBOARD_MEMORY_LOW=64M
BDAG_MINING_ACTIVE_NODE_NICE=-10
BDAG_MINING_POOL_NICE=-8
BDAG_OBSERVABILITY_NICE=15
BDAG_TUNE_NET_QDISC=1
BDAG_STACK_NET_IFACE=

# Release install support services. Fresh appliance installs apply the
# non-destructive host profile by default, then install P2P/IPFS support timers
# and the mining-host tuning timer. Set the strict toggles to fail the install
# instead of warning when host-level service installation cannot complete.
BDAG_INSTALL_APPLIANCE_HOST_PROFILE=1
BDAG_INSTALL_APPLIANCE_PROFILE_DISABLE_SERVICES=0
BDAG_INSTALL_APPLIANCE_PROFILE_RELOAD_DOCKER=1
BDAG_INSTALL_APPLIANCE_PROFILE_STRICT=0
BDAG_INSTALL_STACK_SUPPORT_SERVICES=1
BDAG_INSTALL_STACK_SUPPORT_SERVICES_STRICT=0

# Enables localhost/private-network pool runtime admin endpoints. Keep the pool
# metrics/admin port bound to localhost on public hosts.
POOL_RUNTIME_ADMIN_ENABLED=false
METRICS_ADDR=0.0.0.0:9090
POOL_GBT_MIN_INTERVAL_MS=1100
POOL_GBT_PRESSURE_INTERVAL_MS=500
POOL_GBT_PRESSURE_WINDOW_SECONDS=10
POOL_RPC_ROUTER_NODE_HEALTH_PROBE_SECONDS=15
POOL_RPC_ROUTER_NODE_HEALTH_MAX_AGE_SECONDS=30

# Host network discovery is only for choosing this node's advertised P2P address.
# Peer candidates should be complete P2P multiaddrs.
BDAG_NETWORK_TOPOLOGY=auto
BDAG_DETECTED_NETWORK_TOPOLOGY=
BDAG_ASIC_LAN_INTERFACE=
BDAG_ASIC_LAN_CIDRS=
# Optional route to miners on a remote LAN reached through a routed gateway
# (e.g. a ZeroTier peer). When set, the miner-route compose service keeps the
# host route alive so the watchdog can reach the miner HTTP API. Leave empty
# when miners are on the host LAN.
BDAG_MINER_ROUTE_SUBNET=
BDAG_MINER_ROUTE_GATEWAY=
BDAG_MINER_ROUTE_DEV=
# Docker bridge/container networks must not be treated as ASIC LANs. Override
# only if a real ASIC LAN intentionally uses these ranges.
BDAG_DOCKER_BRIDGE_CIDRS=172.16.0.0/12
BDAG_ALLOW_DOCKER_BRIDGE_ASIC_IPS=0
BDAG_ASIC_EXPECTED_MACS=
BDAG_P2P_ADVERTISE_IP=
BDAG_P2P_INTERFACE=
BDAG_CHAIN_PEERSTORE_PEER_EXTRACTION_ENABLED=1
BDAG_CHAIN_PEERSTORE_LOG_TAIL=8000
EXTRA_PEER_ADDRESSES=

# When enabled by installer/watchdog for attached ASICs, this must include
# --miner, --miningaddr=<non-zero wallet>, and --maxinbound=1 on constrained
# USB/router hosts. Do not add --allowminingwhennearlysynced or
# --allowsubmitwhennotsynced; template/readiness health must fail closed when
# P2P freshness or sync safety is unavailable.
BDAG_NODE_MINING_ARGS=
BDAG_NODE_CHAIN_RPC_TIMEOUT=8.0
BDAG_NODE_CHAIN_RPC_RETRIES=2
BDAG_POOL_RPC_REFUSED_WARN_SECONDS=120
BDAG_CHAIN_STATE_RAWDB_NOT_FOUND_RESTORE_WARNINGS=20
BDAG_HOST_PRESSURE_IOWAIT_WARN_PERCENT=25
BDAG_HOST_PRESSURE_MEMORY_AVAILABLE_WARN_PERCENT=12.0
BDAG_HOST_PRESSURE_SWAP_USED_WARN_PERCENT=5.0
BDAG_HOST_PRESSURE_IOWAIT_WARN_SAMPLES=3
BDAG_HOST_PRESSURE_HISTORY_SAMPLES=6
BDAG_SHARED_STATUS_CACHE_ENABLED=1
BDAG_SHARED_STATUS_CACHE_SECONDS=3.0
BDAG_STATUS_PAYLOAD_STALE_AFTER_SECONDS=120
BDAG_HOST_PROFILE=auto
BDAG_ADAPTIVE_CONCURRENCY_ENABLED=1
BDAG_ADAPTIVE_IOWAIT_WARN_PERCENT=25
BDAG_ADAPTIVE_IO_SOME_AVG10_WARN=20.0
BDAG_ADAPTIVE_CPU_SOME_AVG10_WARN=80.0
BDAG_ADAPTIVE_CHAIN_RPC_WARN_MS=1000
BDAG_ADAPTIVE_MEMORY_AVAILABLE_WARN_PERCENT=12.0
BDAG_ADAPTIVE_SWAP_USED_WARN_PERCENT=5.0
BDAG_STATUS_SAMPLER_ENABLED=1
BDAG_STATUS_SAMPLER_INTERVAL_SECONDS=10
BDAG_STATUS_SAMPLER_MAX_AGE_SECONDS=120
BDAG_NEIGHBOR_MAC_CACHE_SECONDS=2.0
BDAG_COLLECTOR_DIRECT_STATUS_FALLBACK=0
BDAG_COLLECTOR_STATUS_CACHE_SECONDS=120
BDAG_COLLECTOR_SAMPLER_CACHE_SECONDS=120
BDAG_COLLECTOR_STATUS_SAMPLE_WAIT_SECONDS=60
# Destructive chain-state self-heal is disabled by default. Enable it only with
# an explicit trusted IPFS/rawdatadir restore source; sealed rawdatadir/IPFS
# artifact folders are verifier inputs and must not be rsynced as node datadirs.
BDAG_CHAIN_STATE_SELF_HEAL_ENABLED=0
BDAG_CHAIN_STATE_SELF_HEAL_UNIT=bdag-chain-state-self-heal.service
BDAG_MINING_IMPERATIVE_CHAIN_STATE_RESTORE_ENABLED=1
BDAG_CHAIN_STATE_MISSING_TRIE_RESTORE_WARNINGS=3
BDAG_CHAIN_STATE_ACTIVE_MINING_DEFER_SECONDS=180
BDAG_CHAIN_STATE_STALLED_IMPORT_RESTORE_ENABLED=1
BDAG_CHAIN_STATE_STALLED_IMPORT_RESTORE_SECONDS=900
BDAG_CHAIN_STATE_STALLED_IMPORT_RESTORE_PEER_AHEAD_BLOCKS=1000
BDAG_CHAIN_STATE_STALLED_IMPORT_RESTORE_GAP_GROWTH_BLOCKS=60
# Optional trusted restore source for unattended chain-state self-heal.
# Use key-based SSH for remote rsync sources; do not store passwords here.
BDAG_CHAIN_STATE_RESTORE_SOURCE=
BDAG_CHAIN_STATE_RESTORE_SSH_COMMAND=
BDAG_CHAIN_STATE_RESTORE_IPFS_ARTIFACT_CID=
BDAG_CHAIN_STATE_RESTORE_IPFS_INDEX_CID=
BDAG_CHAIN_STATE_RESTORE_IPFS_INDEX_FILE=
BDAG_DASHBOARD_DIRECT_STATUS_FALLBACK=0
BDAG_DASHBOARD_STATUS_CACHE_SECONDS=120
BDAG_DASHBOARD_SAMPLER_CACHE_SECONDS=120
BDAG_DASHBOARD_STATUS_SAMPLE_WAIT_SECONDS=60
BDAG_WATCHDOG_EARNINGS_SNAPSHOT_INTERVAL_SECONDS=60
BDAG_STATUS_SAMPLER_EARNINGS_SNAPSHOT_INTERVAL_SECONDS=60
BDAG_COLLECTOR_EARNINGS_SAMPLER_INTERVAL_SECONDS=60
BDAG_COLLECTOR_GLOBAL_SAMPLER_INTERVAL_SECONDS=60
BDAG_GLOBAL_CACHE_TTL_SECONDS=60
BDAG_GLOBAL_RPC_WORKERS=8
BDAG_GLOBAL_BLOCK_WINDOW=600
BDAG_GLOBAL_CACHE_MAX_TIP_LAG_BLOCKS=30
BDAG_INSTALL_REBUILD_DASHBOARD_PLOTS=1
BDAG_INSTALL_REBUILD_DASHBOARD_PLOT_HOURS=720
BDAG_INSTALL_REBUILD_DASHBOARD_PLOT_WINDOW_BLOCKS=64
BDAG_INSTALL_REBUILD_DASHBOARD_PLOT_WORKERS=12
BDAG_DASHBOARD_HISTORY_REBUILD_PRESERVE_ASIC_HISTORY=1
# Optional native mining RPC list for Global chain-production stats.
# EVM RPC variables are wallet/balance sources only and must not drive Global mining attribution.
BDAG_GLOBAL_CHAIN_RPC_URLS=
BDAG_MINER_SCAN_WORKERS=64
BDAG_MINER_HASHRATE_PROBE_WORKERS=8
BDAG_MINER_REGISTRY_MAX_PORTS=16
BDAG_MINER_REGISTRY_MAX_JOB_EXTRANONCES=64
BDAG_BACKGROUND_MAINTENANCE_BACKOFF_ENABLED=1
BDAG_BACKGROUND_MAINTENANCE_SYNC_BACKOFF_BLOCKS=0
BDAG_BACKGROUND_MAINTENANCE_IOWAIT_WARN_PERCENT=25
BDAG_BACKGROUND_MAINTENANCE_IO_SOME_AVG10_WARN=20.0
BDAG_BACKGROUND_MAINTENANCE_IO_FULL_AVG10_WARN=10.0
BDAG_BACKGROUND_MAINTENANCE_CPU_SOME_AVG10_WARN=80.0
BDAG_BACKGROUND_MAINTENANCE_CHAIN_RPC_WARN_MS=1000
BDAG_BACKGROUND_MAINTENANCE_MEMORY_AVAILABLE_WARN_PERCENT=12.0
BDAG_BACKGROUND_MAINTENANCE_SWAP_USED_WARN_PERCENT=5.0
BDAG_BACKGROUND_MAINTENANCE_POOL_READY_STATUS_MAX_AGE_SECONDS=30
BDAG_BACKGROUND_MAINTENANCE_LAZY_TASKS=dashboard_global_sampler,global_blockchain_scan,global_scan,rawdatadir_sidecar,rawdatadir_content_seal,ipfs_content_sidecar,ipfs_segment_writer,history_compaction
BDAG_BACKGROUND_MAINTENANCE_SYNC_PRIORITY_EXEMPT_TASKS=ipfs_segment_writer
BDAG_BACKGROUND_MAINTENANCE_IO_PRESSURE_EXEMPT_TASKS=
BDAG_BACKGROUND_MAINTENANCE_POOL_READY_TASKS=rawdatadir_content_seal,ipfs_content_sidecar
BDAG_GLOBAL_HISTORY_COMPACT_MULTIPLIER=2
BDAG_ENTRYPOINT_CHOWN_MODE=needed
BDAG_NODEWORKER_LIVENESS_TIMEOUT=5m

# Current Compose/service-name topology. Source Compose intentionally does not
# pin container_name; Docker Compose may append project and ordinal suffixes to
# concrete container names.
BDAG_POOL_CONTAINER=pool
BDAG_POOL_CONTAINERS=pool
BDAG_POOL_DB_CONTAINER=postgres
BDAG_NODE_SERVICE=node
BDAG_STACK_SERVICES=postgres,node,pool
BDAG_START_SERVICES=postgres,node,pool
POOL_ASIC_MAC_OVERRIDES=
BDAG_NODE_RPC_URL=http://node:38131

# Raw datadir and IPFS sidecar. Installer enables low-priority timers that keep
# local seed material current without competing aggressively with mining.
BDAG_BTRFS_CHECKPOINT_VOLUME_MODE=auto
BDAG_BTRFS_CHECKPOINT_VOLUME_SIZE_GIB=128
BDAG_BTRFS_CHECKPOINT_VOLUME_MIN_ROOT_FREE_GIB=40
BDAG_BTRFS_CHECKPOINT_VOLUME_IMAGE=
BDAG_BTRFS_CHECKPOINT_VOLUME_MOUNT=./data-restore/btrfs-checkpoints
BDAG_BTRFS_CHECKPOINT_VOLUME_LABEL=bdag-raw-checkpoints
BDAG_BTRFS_CHECKPOINT_VOLUME_OPTIONS=noatime,compress=zstd:1,space_cache=v2
BDAG_RAWDATADIR_NETWORK=mainnet
BDAG_RAWDATADIR_SIDECAR_MODE=auto
BDAG_RAWDATADIR_ARTIFACT_BASE=./data-restore/btrfs-checkpoints/rawdatadir-artifacts
BDAG_RAWDATADIR_ARTIFACT_KEEP=3
BDAG_RAWDATADIR_REQUIRE_SIGNED=1
BDAG_RAWDATADIR_REQUIRE_EVM_REFERENCE_FRESH=1
BDAG_RAWDATADIR_MAX_EVM_REFERENCE_LAG=1000
BDAG_PUBLIC_RPC_URLS=bdagscan-rpc=https://rpc.bdagscan.com,blockdag-engineering-rpc=https://rpc.blockdag.engineering
BDAG_RAWDATADIR_SIDECAR_SOURCE=
BDAG_RAWDATADIR_SIDECAR_DIR=./data-restore/btrfs-checkpoints/rawdatadir-sidecar/mainnet
BDAG_RAWDATADIR_SIDECAR_CONTENT_MODE=auto
BDAG_RAWDATADIR_SIDECAR_CONTENT_BASE=./data-restore/btrfs-checkpoints/rawdatadir-sidecar-content
BDAG_RAWDATADIR_SIDECAR_CONTENT_KEEP=2
BDAG_RAWDATADIR_SIDECAR_CONTENT_CHUNK_SIZE=67108864
BDAG_RAWDATADIR_SIDECAR_CONTENT_REQUIRE_SIGNED=1
BDAG_RAWDATADIR_SIDECAR_CONTENT_ALLOW_HOT_PUBLISH=0
BDAG_RAWDATADIR_OPEN_SIDECAR_ENABLED=1
BDAG_RAWDATADIR_OPEN_SIDECAR_BASE=./data-restore/btrfs-checkpoints/rawdatadir-sidecar-open/mainnet
BDAG_RAWDATADIR_OPEN_SIDECAR_KEEP=12
BDAG_RAWDATADIR_SIDECAR_RSYNC_BWLIMIT=4096
BDAG_RAWDATADIR_SIDECAR_CATCHUP_RSYNC_BWLIMIT=1024
BDAG_RAWDATADIR_SIDECAR_DELAY_UPDATES=0
BDAG_RAWDATADIR_ACTIVE_SERVICE=node
BDAG_RAWDATADIR_FINALIZE=0
BDAG_RAWDATADIR_MIN_FREE_GIB=100
BDAG_RAWDATADIR_FREE_SPACE_MULTIPLIER=2.5
BDAG_RAWDATADIR_REQUIRE_STATE_ROOT=1
BDAG_RAWDATADIR_SIDECAR_USE_SUDO=auto
BDAG_RAWDATADIR_ARCHIVE_USE_SUDO=auto
BDAG_RAWDATADIR_SIGNING_KEY_ID=
BDAG_RAWDATADIR_SIGNING_KEY_HEX=
BDAG_RAWDATADIR_SIGNING_KEY_FILE=./ops/runtime/ipfs-content/segment-writer.key
BDAG_RAWDATADIR_TRUSTED_SIGNERS=
BDAG_RAWDATADIR_REQUIRE_TRUSTED_SIGNER=1
BDAG_RAWDATADIR_REQUIRE_CHAIN_ANCHOR=1
BDAG_RAWDATADIR_CHAIN_ANCHOR_REFERENCE_EVM_URL=https://rpc.blockdag.engineering
BDAG_RAWDATADIR_CHAIN_ANCHOR_TIMEOUT=8
BDAG_RAWDATADIR_CHAIN_ANCHOR_FINALITY_BLOCKS=600

# Lazy IPFS content sidecar. The rawdatadir sidecar seals immutable signed
# file/chunk generations into BDAG_RAWDATADIR_SIDECAR_CONTENT_BASE; IPFS pins
# only publishable generations after mining and host resource gates pass. IPFS
# is byte transport; signed manifests and consensus validation remain
# authoritative.
BDAG_IPFS_CONTENT_SIDECAR_MODE=auto
BDAG_IPFS_CONTENT_ARTIFACT_DIR=./data-restore/btrfs-checkpoints/rawdatadir-sidecar-content/current
BDAG_IPFS_CONTENT_ARTIFACT_MANIFEST=./data-restore/btrfs-checkpoints/rawdatadir-sidecar-content/current/manifest.json
BDAG_IPFS_CONTENT_ALLOW_UNSIGNED_ARTIFACT=0
BDAG_IPFS_CONTENT_PUBLISH_IPNS=auto
BDAG_IPFS_CONTENT_IPNS_KEY=
BDAG_IPFS_CONTENT_REPUBLISH_IPNS_WHILE_WAITING=1
BDAG_IPFS_CONTENT_IPNS_TTL=1m
BDAG_IPFS_CONTENT_IPNS_LIFETIME=8760h
BDAG_IPFS_CONTENT_ADD_ARGS="--recursive --cid-version=1 --raw-leaves --pin=true --quieter"
BDAG_IPFS_CONTENT_DISCOVERY_FILE=./ops/ipfs-content-discovery.json
BDAG_IPFS_CONTENT_LATEST_IPNS=/ipns/k51qzi5uqu5djjlh4vxtmzyswx0qk4s3wdlf3yrpkszp38gq5sl71zcgmmc3jk
BDAG_IPFS_CONTENT_DEFAULT_INDEX_CID=bafkreia7jk2ljqi3raiohugp6nw3633njfp7jmnuvqh47po52et4kupu2a
BDAG_IPFS_RAWDATADIR_CONTENT_INDEX_PATH=./ops/runtime/ipfs-content/rawdatadir-content-index.json
BDAG_IPFS_RAWDATADIR_CONTENT_DEFAULT_INDEX_CID=
BDAG_IPFS_RAWDATADIR_CONTENT_PUBLISH_IPNS=auto
BDAG_IPFS_RAWDATADIR_CONTENT_IPNS_KEY=
BDAG_IPFS_STATE_CHECKPOINT_REQUIRED=1
BDAG_RESTORE_POINT_MAX_AGE_SECONDS=600
BDAG_RESTORE_GUARD_IPFS_TIMERS=bdag-rawdatadir-sidecar.timer,bdag-rawdatadir-sidecar-verify.timer,bdag-ipfs-content-sidecar.timer
BDAG_IPFS_PEER_ROSTER_ENABLED=1
BDAG_IPFS_PEER_ROSTER_INDEX_PATH=./ops/runtime/ipfs-content/peer-roster.json
BDAG_IPFS_PEER_ROSTER_STATUS_FILE=./ops/runtime/ipfs-content/peer-roster-status.json
BDAG_IPFS_PEER_ROSTER_DEFAULT_CID=
BDAG_IPFS_PEER_ROSTER_IPNS=
BDAG_IPFS_PEER_ROSTER_PUBLISH_IPFS=1
BDAG_IPFS_PEER_ROSTER_MAX_PEERS=64
BDAG_IPFS_PEER_ROSTER_REQUIRE_SIGNATURES=1
BDAG_IPFS_PEER_ROSTER_ADD_ARGS="--cid-version=1 --pin=true --quieter"
BDAG_IPFS_CONTENT_DEFAULT_ROOT_CID=
BDAG_IPFS_CONTENT_STATUS_FILE=./ops/runtime/ipfs-content-sidecar-status.json
BDAG_IPFS_CONTENT_LATEST_INDEX_PATH=./ops/runtime/ipfs-content/latest-index.json
BDAG_IPFS_SEGMENT_WRITER_MODE=auto
BDAG_IPFS_SEGMENT_WRITER_ID=
BDAG_IPFS_SEGMENT_WRITER_ROSTER=
BDAG_IPFS_SEGMENT_WRITER_ELECTION_RULE=rendezvous_sha256_v1
BDAG_IPFS_SEGMENT_BOOTSTRAP_LOCAL_PUBLISH=0
BDAG_IPFS_SEGMENT_BOOTSTRAP_UNTRUSTED_PUBLISH=0
BDAG_IPFS_SEGMENT_START_POLICY=live_tail
BDAG_IPFS_SEGMENT_STALE_HEAD_RESET_ENABLED=1
BDAG_IPFS_SEGMENT_STALE_HEAD_MAX_LAG_ORDERS=3600
BDAG_IPFS_SEGMENT_FINALITY_LAG_ORDERS=600
BDAG_IPFS_SEGMENT_ORDERS_PER_SEGMENT=300
BDAG_CHAIN_INTEGRITY_MAX_SEGMENT_ORDERS=300
BDAG_IPFS_SEGMENT_MAX_SEGMENTS_PER_RUN=1
BDAG_IPFS_SEGMENT_MAX_RPC_PER_SECOND=25
BDAG_IPFS_SEGMENT_RPC_TIMEOUT=8
BDAG_IPFS_SEGMENT_BLOCK_RPC_RETRIES=2
# Trusted chain-order IPFS publication needs an independent native BlockDAG RPC.
# Public EVM RPCs can support dashboard/public-chain alignment, but they must
# not be treated as proof for raw chain-order segment bytes.
BDAG_NATIVE_REFERENCE_RPC_MODE=auto
BDAG_NATIVE_REFERENCE_RPC_URL=
BDAG_NATIVE_REFERENCE_RPC_SSH_TARGET=
BDAG_NATIVE_REFERENCE_RPC_REMOTE_HOST=127.0.0.1
BDAG_NATIVE_REFERENCE_RPC_REMOTE_PORT=38131
BDAG_NATIVE_REFERENCE_RPC_LOCAL_BIND=127.0.0.1
BDAG_NATIVE_REFERENCE_RPC_LOCAL_PORT=38141
BDAG_NATIVE_REFERENCE_RPC_START_TUNNEL=1
BDAG_NATIVE_REFERENCE_RPC_STRICT=0
BDAG_NATIVE_REFERENCE_RPC_KEY_PATH=./ops/runtime/native-reference-rpc/id_ed25519
BDAG_NATIVE_REFERENCE_RPC_KNOWN_HOSTS=./ops/runtime/native-reference-rpc/known_hosts
BDAG_CHAIN_REFERENCE_RPC_URL=
BDAG_IPFS_SEGMENT_REFERENCE_RPC_URL=
BDAG_IPFS_SEGMENT_PUBLISH_IPNS=auto
BDAG_IPFS_SEGMENT_IPNS_KEY=
BDAG_IPFS_SEGMENT_RESTORE_DIR=./ops/runtime/ipfs-segment-restore-drills
BDAG_IPFS_SEGMENT_IPNS_TTL=1m
BDAG_IPFS_SEGMENT_IPNS_LIFETIME=8760h
BDAG_IPFS_SEGMENT_SIGNING_KEY_FILE=./ops/runtime/ipfs-content/segment-writer.key
BDAG_IPFS_SEGMENT_TRUSTED_SIGNERS=
BDAG_IPFS_SEGMENT_REQUIRE_SIGNATURES=1
BDAG_IPFS_SEGMENT_STATUS_FILE=./ops/runtime/ipfs-content/segment-writer-status.json
BDAG_IPFS_SEGMENT_INDEX_PATH=./ops/runtime/ipfs-content/latest-index.json
BDAG_IPFS_RESTORE_MODE=verify
BDAG_IPFS_RESTORE_MAX_SEGMENTS=16
BDAG_IPFS_RESTORE_MATERIALIZE=0
BDAG_IPFS_RESTORE_REQUIRE_SIGNATURES=1
BDAG_IPFS_RESTORE_VERIFY_INDEX_LINEAGE=1
BDAG_IPFS_RESTORE_MAX_INDEX_LINEAGE_DEPTH=256
BDAG_IPFS_RESTORE_ACCEPTED_HEAD_ENABLED=1
BDAG_IPFS_RESTORE_ACCEPTED_HEAD_STATE_FILE=./ops/runtime/ipfs-content/restore-accepted-head.json
BDAG_IPFS_RESTORE_CHAIN_ANCHOR_ENABLED=1
BDAG_IPFS_RESTORE_REQUIRE_CHAIN_ANCHOR=0
BDAG_IPFS_RESTORE_CHAIN_SOURCE_RPC_URL=
BDAG_IPFS_RESTORE_CHAIN_REFERENCE_RPC_URL=
BDAG_IPFS_RESTORE_CHAIN_ANCHOR_FULL_SPAN_MAX_ORDERS=300
BDAG_IPFS_RESTORE_CHAIN_ANCHOR_SKIP_ENVIRONMENT_GATES=1
BDAG_IPFS_RESTORE_PRESTART_DRILL=1
BDAG_IPFS_RESTORE_PRESTART_STRICT=0
BDAG_IPFS_RAWDATADIR_RESTORE_PRESTART=1
BDAG_IPFS_RAWDATADIR_RESTORE_PRESTART_STRICT=0
BDAG_IPFS_RAWDATADIR_RESTORE_ARTIFACT_CID=
BDAG_IPFS_RAWDATADIR_RESTORE_INDEX_CID=
BDAG_IPFS_RAWDATADIR_RESTORE_INDEX_FILE=
BDAG_IPFS_RAWDATADIR_RESTORE_DISCOVERY_FILE=./ops/ipfs-content-discovery.json
BDAG_IPFS_RAWDATADIR_RESTORE_STATUS_FILE=./ops/runtime/ipfs-content/rawdatadir-restore-status.json
BDAG_IPFS_RAWDATADIR_RESTORE_IPFS_TIMEOUT=600
BDAG_IPFS_BACKFILL_INDEX_PATH=./ops/runtime/ipfs-content/backfill-genesis-index.json
BDAG_IPFS_BACKFILL_STATUS_FILE=./ops/runtime/ipfs-content/backfill-status.json
BDAG_IPFS_BACKFILL_START_ORDER=1
BDAG_IPFS_BACKFILL_MAX_SEGMENTS_PER_RUN=1
BDAG_IPFS_RESTORE_STATUS_FILE=./ops/runtime/ipfs-content/restore-drill-status.json
BDAG_IPFS_RESTORE_CANDIDATE_DIR=./ops/runtime/ipfs-content/restore-candidate

# P2P startup peers. Entries must be complete P2P multiaddrs with peer IDs.
# Address class is not a sync mode or priority signal.
