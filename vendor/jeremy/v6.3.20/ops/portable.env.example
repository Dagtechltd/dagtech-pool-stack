# Copy this to ops/runtime/ops.env on a new pool host and edit it there.
# The installer writes the path values automatically, but this file documents
# the knobs that make the dashboard portable across pool stacks.

# Filesystem locations.
# BDAG_PROJECT_ROOT=/opt/blockdag-asic-pool
# BDAG_RUNTIME_DIR=/var/lib/bdag-dashboard
# BDAG_POOL_ENV_FILE=/opt/blockdag-asic-pool/.env
# BDAG_DATA_DIR=/opt/blockdag-asic-pool/data

# Dashboard listener. Keep this on 127.0.0.1 and use SSH forwarding unless the
# host is on a trusted private management network.
BDAG_DASHBOARD_BIND=127.0.0.1
BDAG_DASHBOARD_PORT=8088
BDAG_DASHBOARD_REQUIRE_TOKEN=auto
BDAG_DASHBOARD_DIRECT_STATUS_FALLBACK=0
BDAG_DASHBOARD_STATUS_CACHE_SECONDS=120
BDAG_DASHBOARD_SAMPLER_CACHE_SECONDS=120
BDAG_DASHBOARD_STATUS_SAMPLE_WAIT_SECONDS=60
BDAG_DASHBOARD_EARNINGS_SAMPLER_INTERVAL_SECONDS=60
BDAG_DASHBOARD_GLOBAL_SAMPLER_INTERVAL_SECONDS=60
BDAG_STATUS_PAYLOAD_STALE_AFTER_SECONDS=120
BDAG_STATUS_SAMPLER_MAX_AGE_SECONDS=120
BDAG_CATCHUP_PAUSE_ENABLED=1
BDAG_CATCHUP_PAUSE_THRESHOLD_BLOCKS=300
BDAG_CATCHUP_IO_PRESSURE_PAUSE_ENABLED=1
BDAG_CATCHUP_IO_PRESSURE_MIN_LAG_BLOCKS=25
BDAG_CATCHUP_IOWAIT_WARN_PERCENT=15
BDAG_CATCHUP_IO_SOME_AVG10_WARN=20.0
BDAG_CATCHUP_IO_FULL_AVG10_WARN=10.0
BDAG_CATCHUP_NODE_RECREATE_ENABLED=1
BDAG_CATCHUP_NODE_CACHE_MB=1024
BDAG_CATCHUP_NODE_CACHE_MIN_MB=512
BDAG_CATCHUP_NODE_CACHE_MEMORY_PERCENT=15
BDAG_HOST_PRESSURE_MEMORY_AVAILABLE_WARN_PERCENT=12.0
BDAG_HOST_PRESSURE_SWAP_USED_WARN_PERCENT=5.0
BDAG_ADAPTIVE_MEMORY_AVAILABLE_WARN_PERCENT=12.0
BDAG_ADAPTIVE_SWAP_USED_WARN_PERCENT=5.0
BDAG_NODE_MEMORY_HIGH=auto
BDAG_NODE_MEMORY_HIGH_PERCENT=60
BDAG_NODE_MEMORY_HIGH_MIN=3072M
BDAG_CHAIN_STATE_SELF_HEAL_ENABLED=0
BDAG_CHAIN_STATE_SELF_HEAL_UNIT=bdag-chain-state-self-heal.service
BDAG_MINING_IMPERATIVE_CHAIN_STATE_RESTORE_ENABLED=1
BDAG_CHAIN_STATE_STALLED_IMPORT_RESTORE_ENABLED=1
BDAG_CHAIN_STATE_STALLED_IMPORT_RESTORE_SECONDS=900
BDAG_CHAIN_STATE_STALLED_IMPORT_RESTORE_PEER_AHEAD_BLOCKS=1000
BDAG_CHAIN_STATE_STALLED_IMPORT_RESTORE_GAP_GROWTH_BLOCKS=60
# Optional trusted restore source for unattended chain-state self-heal.
# Use key-based SSH for remote rsync sources; do not store passwords here.
# BDAG_CHAIN_STATE_RESTORE_SOURCE=/srv/bdag-chain/mainnet
# BDAG_CHAIN_STATE_RESTORE_SOURCE=pool-admin@192.168.1.20:/srv/bdag-chain/mainnet
# BDAG_CHAIN_STATE_RESTORE_SSH_COMMAND=ssh -i /home/pool-admin/.ssh/bdag-chain-restore -o BatchMode=yes
BDAG_WATCHDOG_EARNINGS_SNAPSHOT_INTERVAL_SECONDS=60
BDAG_STATUS_SAMPLER_EARNINGS_SNAPSHOT_INTERVAL_SECONDS=60

# Pool identity and miner defaults.
# BDAG_MINING_ADDRESS=0x0000000000000000000000000000000000000000
# BDAG_POOL_PORT=3334
# BDAG_POOL_HOST=192.168.1.10
# BDAG_POOL_URL=stratum+tcp://192.168.1.10:3334
# BDAG_MINER_SCAN_TARGET=192.168.1.0/24
# BDAG_MINER_POOL_PASSWORD=1234

# Docker/container mapping. Change these if another pool uses different names.
BDAG_POOL_CONTAINER=pool
BDAG_POOL_CONTAINERS=pool
BDAG_POOL_DB_CONTAINER=postgres
BDAG_POOL_DB_USER=test
BDAG_POOL_DB_NAME=pool
BDAG_NODE_SERVICE=node
BDAG_STACK_SERVICES=postgres,node,pool
BDAG_START_SERVICES=postgres,node,pool
BDAG_ASIC_EXPECTED_MACS=
POOL_ASIC_MAC_OVERRIDES=

# If the dashboard runs away from the pool host, use Docker's SSH transport.
# Example: DOCKER_HOST=ssh://pool-admin@192.168.1.10
# DOCKER_HOST=

# Host-run dashboard and watchdog processes must use host-reachable RPC URLs.
# Compose-only names such as http://node:38131 are valid inside containers but
# will freeze host-side global scans if copied into ops/runtime/ops.env.
BDAG_BACKGROUND_MAINTENANCE_SYNC_PRIORITY_EXEMPT_TASKS=ipfs_segment_writer
BDAG_BACKGROUND_MAINTENANCE_IO_PRESSURE_EXEMPT_TASKS=
BDAG_BACKGROUND_MAINTENANCE_MEMORY_AVAILABLE_WARN_PERCENT=12.0
BDAG_BACKGROUND_MAINTENANCE_SWAP_USED_WARN_PERCENT=5.0
BDAG_BACKGROUND_MAINTENANCE_POOL_READY_TASKS=rawdatadir_content_seal,ipfs_content_sidecar
BDAG_BTRFS_CHECKPOINT_VOLUME_MODE=auto
BDAG_BTRFS_CHECKPOINT_VOLUME_SIZE_GIB=128
BDAG_BTRFS_CHECKPOINT_VOLUME_MIN_ROOT_FREE_GIB=40
BDAG_BTRFS_CHECKPOINT_VOLUME_IMAGE=
BDAG_BTRFS_CHECKPOINT_VOLUME_MOUNT=./data-restore/btrfs-checkpoints
BDAG_BTRFS_CHECKPOINT_VOLUME_LABEL=bdag-raw-checkpoints
BDAG_BTRFS_CHECKPOINT_VOLUME_OPTIONS=noatime,compress=zstd:1,space_cache=v2
BDAG_RAWDATADIR_NETWORK=mainnet
BDAG_RAWDATADIR_ARTIFACT_BASE=./data-restore/btrfs-checkpoints/rawdatadir-artifacts
BDAG_RAWDATADIR_SIDECAR_DIR=./data-restore/btrfs-checkpoints/rawdatadir-sidecar/mainnet
BDAG_RAWDATADIR_SIDECAR_CONTENT_BASE=./data-restore/btrfs-checkpoints/rawdatadir-sidecar-content
BDAG_RAWDATADIR_OPEN_SIDECAR_ENABLED=1
BDAG_RAWDATADIR_OPEN_SIDECAR_BASE=./data-restore/btrfs-checkpoints/rawdatadir-sidecar-open/mainnet
BDAG_RAWDATADIR_OPEN_SIDECAR_KEEP=12
BDAG_RAWDATADIR_SIDECAR_RSYNC_BWLIMIT=4096
BDAG_RAWDATADIR_SIDECAR_CATCHUP_RSYNC_BWLIMIT=1024
BDAG_RAWDATADIR_SIDECAR_DELAY_UPDATES=0
BDAG_RAWDATADIR_SIGNING_KEY_FILE=./ops/runtime/ipfs-content/segment-writer.key
BDAG_RAWDATADIR_TRUSTED_SIGNERS=
BDAG_RAWDATADIR_REQUIRE_TRUSTED_SIGNER=1
BDAG_RAWDATADIR_REQUIRE_CHAIN_ANCHOR=1
BDAG_RAWDATADIR_CHAIN_ANCHOR_REFERENCE_EVM_URL=https://rpc.blockdag.engineering
BDAG_RAWDATADIR_CHAIN_ANCHOR_TIMEOUT=8
BDAG_RAWDATADIR_CHAIN_ANCHOR_FINALITY_BLOCKS=600
BDAG_IPFS_CONTENT_ARTIFACT_DIR=./data-restore/btrfs-checkpoints/rawdatadir-sidecar-content/current
BDAG_IPFS_CONTENT_ARTIFACT_MANIFEST=./data-restore/btrfs-checkpoints/rawdatadir-sidecar-content/current/manifest.json
BDAG_IPFS_RAWDATADIR_CONTENT_INDEX_PATH=./ops/runtime/ipfs-content/rawdatadir-content-index.json
BDAG_IPFS_RAWDATADIR_CONTENT_DEFAULT_INDEX_CID=
BDAG_IPFS_RAWDATADIR_CONTENT_PUBLISH_IPNS=auto
BDAG_IPFS_RAWDATADIR_CONTENT_IPNS_KEY=
BDAG_IPFS_STATE_CHECKPOINT_REQUIRED=1
BDAG_RESTORE_POINT_MAX_AGE_SECONDS=600
BDAG_RESTORE_GUARD_IPFS_TIMERS=bdag-rawdatadir-sidecar.timer,bdag-rawdatadir-sidecar-verify.timer,bdag-ipfs-content-sidecar.timer
BDAG_IPFS_PEER_ROSTER_ENABLED=1
BDAG_IPFS_PEER_ROSTER_INDEX_PATH=./ops/runtime/ipfs-content/peer-roster.json
BDAG_IPFS_PEER_ROSTER_STATUS_FILE=./ops/runtime/ipfs-content/peer-roster-status.json
BDAG_IPFS_PEER_ROSTER_DEFAULT_CID=
BDAG_IPFS_PEER_ROSTER_IPNS=
BDAG_IPFS_PEER_ROSTER_PUBLISH_IPFS=1
BDAG_IPFS_PEER_ROSTER_MAX_PEERS=64
BDAG_IPFS_PEER_ROSTER_REQUIRE_SIGNATURES=1
BDAG_IPFS_PEER_ROSTER_ADD_ARGS="--cid-version=1 --pin=true --quieter"
BDAG_IPFS_RAWDATADIR_RESTORE_PRESTART=1
BDAG_IPFS_RAWDATADIR_RESTORE_PRESTART_STRICT=0
BDAG_IPFS_RAWDATADIR_RESTORE_ARTIFACT_CID=
BDAG_IPFS_RAWDATADIR_RESTORE_INDEX_CID=
BDAG_IPFS_RAWDATADIR_RESTORE_INDEX_FILE=
BDAG_IPFS_RAWDATADIR_RESTORE_DISCOVERY_FILE=./ops/ipfs-content-discovery.json
BDAG_IPFS_RAWDATADIR_RESTORE_STATUS_FILE=./ops/runtime/ipfs-content/rawdatadir-restore-status.json
BDAG_NODE_RPC_URL=http://127.0.0.1:38131
BDAG_GLOBAL_CHAIN_RPC_URLS=node=http://127.0.0.1:38131
NODE_RPC_URL=http://127.0.0.1:38131
# BDAG_PUBLIC_RPC_URLS=engineering=https://rpc.blockdag.engineering,bdagscan=https://rpc.bdagscan.com
# BDAG_EXPLORER_API_URLS=bdagscan=https://bdagscan.com
# BDAG_BLOCKSCOUT_V2_URLS=engineering=https://explorer.blockdag.engineering

# Repair commands. Use wrapper scripts if your target stack is not controlled by
# the Makefile in this repository.
# BDAG_START_COMMAND=make up
# BDAG_STOP_COMMAND=make down
# BDAG_CLEAN_RESTORE_COMMAND=
# BDAG_RESTORE_NODE_COMMAND=

# CoinMarketCap. The dashboard can scrape the public page, but an API key is
# preferred if you have one.
# CMC_PRO_API_KEY=
BDAG_CMC_ID=31162
BDAG_CMC_SLUG=blockdag
