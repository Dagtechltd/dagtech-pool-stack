[Unit]
Description=BlockDAG visible Codex auto-resume terminal
After=graphical-session.target bdag-dashboard.service
Wants=bdag-dashboard.service
PartOf=graphical-session.target

[Service]
Type=oneshot
WorkingDirectory=/home/jeremy/blockdag-asic-pool
Environment=BDAG_PROJECT_ROOT=/home/jeremy/blockdag-asic-pool
Environment=BDAG_RUNTIME_DIR=/home/jeremy/blockdag-asic-pool/ops/runtime
EnvironmentFile=-/home/jeremy/blockdag-asic-pool/ops/runtime/ops.env
ExecStart=/usr/bin/env python3 /home/jeremy/blockdag-asic-pool/ops/codex_auto_resume.py
Nice=15
IOSchedulingClass=idle
CPUWeight=10
IOWeight=10
Restart=on-failure
RestartSec=15

[Install]
WantedBy=graphical-session.target
