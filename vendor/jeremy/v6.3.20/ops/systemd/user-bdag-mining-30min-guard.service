[Unit]
Description=BlockDAG thirty-minute mining proof-of-health guard
After=default.target

[Service]
Type=oneshot
WorkingDirectory=/home/jeremy/blockdag-asic-pool
Environment=BDAG_PROJECT_ROOT=/home/jeremy/blockdag-asic-pool
Environment=BDAG_RUNTIME_DIR=/home/jeremy/blockdag-asic-pool/ops/runtime
EnvironmentFile=-/home/jeremy/blockdag-asic-pool/ops/runtime/ops.env
ExecStart=/usr/bin/env python3 /home/jeremy/blockdag-asic-pool/ops/mining_guard_30min.py --once
Nice=15
IOSchedulingClass=idle
CPUWeight=10
IOWeight=10
