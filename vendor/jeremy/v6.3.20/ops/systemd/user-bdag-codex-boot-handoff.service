[Unit]
Description=BlockDAG Codex boot handoff verifier
After=bdag-boot-repair.service bdag-dashboard.service bdag-watchdog.service default.target
Wants=bdag-boot-repair.service bdag-dashboard.service bdag-watchdog.service

[Service]
Type=oneshot
WorkingDirectory=/home/jeremy/blockdag-asic-pool
Environment=BDAG_PROJECT_ROOT=/home/jeremy/blockdag-asic-pool
Environment=BDAG_RUNTIME_DIR=/home/jeremy/blockdag-asic-pool/ops/runtime
Environment=BDAG_CODEX_BOOT_DASHBOARD_URL=http://127.0.0.1:8088/api/status
EnvironmentFile=-/home/jeremy/blockdag-asic-pool/ops/runtime/ops.env
ExecStart=/usr/bin/env python3 /home/jeremy/blockdag-asic-pool/ops/codex_boot_handoff.py --repair
SuccessExitStatus=2
Nice=15
IOSchedulingClass=idle
CPUWeight=10
IOWeight=10

[Install]
WantedBy=default.target
