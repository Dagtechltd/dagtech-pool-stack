[Unit]
Description=BlockDAG P2P and mining network health guard
After=bdag-dashboard.service default.target

[Service]
Type=simple
WorkingDirectory=/home/jeremy/blockdag-asic-pool
Environment=BDAG_P2P_GUARD_INTERVAL=300
Environment=BDAG_POOL_ACTIVITY_LOG_LINES=1200
EnvironmentFile=-/home/jeremy/blockdag-asic-pool/ops/runtime/ops.env
Nice=8
IOSchedulingClass=best-effort
IOSchedulingPriority=7
CPUWeight=30
IOWeight=30
ExecStartPre=/bin/sh -c 'i=0; while [ "$i" -lt 60 ]; do (docker info >/dev/null 2>&1 || sudo -n docker info >/dev/null 2>&1) && curl -fsS http://127.0.0.1:8088/api/status >/dev/null 2>&1 && exit 0; i=$((i+1)); sleep 5; done; exit 1'
ExecStart=/usr/bin/python3 /home/jeremy/blockdag-asic-pool/ops/p2p_guard.py --loop
Restart=always
RestartSec=15

[Install]
WantedBy=default.target
