#!/usr/bin/env python3
# JARVIS cantina-cutover: Phase C executor.
# - Runs the 60s pre-cutover health gate (6 checks, all must pass)
# - On pass: PUTs X100 pool slot 0 from production hans-solo (3336) to
#   candidate hans-solo (3346), then PUT /mcb/restart
# - Switches the bench phase env to 'implementation' for 15 min, then 'post'
# - Watches first 3 shares (must land <90s) and hashrate recovery (>=200 MH/s <3min)
# - Auto-rollback on any health miss
#
# Dry-run mode (default): prints what it would do, makes no PUTs.
# Live mode: --confirm and the X100 firmware actually gets the PUT.
from __future__ import annotations
import argparse
import json
import os
import socket
import subprocess
import sys
import time
import urllib.parse
import urllib.request
from pathlib import Path

X100_HTTP = "http://192.168.1.20"
X100_USER = "admin"
X100_PASS = "123456789"
X100_CGMINER = ("192.168.1.20", 4028)
PROD_POOL_URL = "stratum+tcp://192.168.1.21:3336"
CANDIDATE_POOL_URL = "stratum+tcp://192.168.1.21:3346"
X100_WALLET = "0x6387C32ccDD60BfBa00EC70A67715Dcd52E8083f"
EVM_RPC = "http://127.0.0.1:18545"
CANDIDATE_EVM_RPC = "http://127.0.0.1:18555"
TG_BOT = "8769759253:AAFd-7c1pJZ1DTuKdCXeC2h6HAutPZES6KA"
TG_CHAT = "6709307529"
TG_URL = "http://10.10.0.1:8443"
LOG = Path("/opt/jarvis/log/cantina-cutover.log")


def log(msg):
    line = time.strftime("%FT%TZ", time.gmtime()) + " " + msg
    print(line, flush=True)
    LOG.parent.mkdir(parents=True, exist_ok=True)
    with open(LOG, "a") as f:
        f.write(line + "\n")


def telegram(text):
    try:
        data = urllib.parse.urlencode({"chat_id": TG_CHAT, "text": text}).encode()
        urllib.request.urlopen(
            urllib.request.Request(TG_URL + "/bot" + TG_BOT + "/sendMessage",
                                   data=data, method="POST"),
            timeout=10,
        )
    except Exception as exc:
        log("telegram failed: " + str(exc))


def x100_jwt():
    url = X100_HTTP + "/user/login?username=" + X100_USER + "&password=" + X100_PASS
    r = urllib.request.urlopen(url, timeout=5)
    return json.loads(r.read())["JWT Token"]


def x100_get_pools(jwt):
    req = urllib.request.Request(X100_HTTP + "/mcb/pools",
                                 headers={"Authorization": "Bearer " + jwt})
    return json.loads(urllib.request.urlopen(req, timeout=5).read())


def x100_put_pools(jwt, body):
    req = urllib.request.Request(X100_HTTP + "/mcb/pools",
                                 data=json.dumps(body).encode(),
                                 method="PUT",
                                 headers={"Authorization": "Bearer " + jwt,
                                          "Content-Type": "application/json"})
    return urllib.request.urlopen(req, timeout=10).read()


def x100_restart(jwt):
    req = urllib.request.Request(X100_HTTP + "/mcb/restart", method="PUT",
                                 data=b"",
                                 headers={"Authorization": "Bearer " + jwt})
    return urllib.request.urlopen(req, timeout=10).read()


def cgminer_cmd(cmd):
    s = socket.socket()
    s.settimeout(3)
    s.connect(X100_CGMINER)
    s.sendall(cmd.encode())
    chunks = []
    while True:
        try:
            d = s.recv(8192)
            if not d:
                break
            chunks.append(d)
        except socket.timeout:
            break
    s.close()
    return b"".join(chunks).decode(errors="replace")


def rpc(url, method, params=None):
    body = json.dumps({"jsonrpc": "2.0", "id": 1, "method": method,
                       "params": params or []}).encode()
    req = urllib.request.Request(url, data=body,
                                 headers={"Content-Type": "application/json"},
                                 method="POST")
    with urllib.request.urlopen(req, timeout=5) as r:
        return json.loads(r.read())


def tcp_open(host, port, timeout=3):
    try:
        s = socket.socket()
        s.settimeout(timeout)
        s.connect((host, int(port)))
        s.close()
        return True
    except Exception:
        return False


def stratum_subscribe(host, port):
    s = socket.socket()
    s.settimeout(3)
    s.connect((host, int(port)))
    s.sendall(b'{"id":1,"method":"mining.subscribe","params":["jarvis-probe/0.1"]}\n')
    try:
        line = s.recv(4096).decode(errors="replace")
        s.close()
        return "result" in line
    except Exception:
        s.close()
        return False


# --- Pre-cutover health gate ---------------------------------------------

CHECKS = []
def check(name):
    def deco(fn):
        CHECKS.append((name, fn))
        return fn
    return deco


@check("X100 cgminer reports Status=Alive")
def chk_x100_alive():
    raw = cgminer_cmd("devs")
    return "Status=Alive" in raw, raw[:200]


@check("candidate hans-solo stratum responds to mining.subscribe")
def chk_candidate_stratum():
    if not tcp_open("127.0.0.1", 3346):
        return False, "3346 not open"
    return stratum_subscribe("127.0.0.1", 3346), "subscribed"


@check("candidate node EVM tip within 1 block of production")
def chk_tip_lag():
    try:
        prod = int(rpc(EVM_RPC, "eth_blockNumber")["result"], 16)
        cand = int(rpc(CANDIDATE_EVM_RPC, "eth_blockNumber")["result"], 16)
        return abs(prod - cand) <= 1, f"prod={prod} cand={cand}"
    except Exception as exc:
        return False, str(exc)


@check("candidate has >= 5 connected peers")
def chk_peers():
    try:
        n = int(rpc(CANDIDATE_EVM_RPC, "net_peerCount")["result"], 16)
        return n >= 5, f"peers={n}"
    except Exception as exc:
        return False, str(exc)


@check("all cantina containers healthy")
def chk_containers():
    expected = ["cantina-pool-db", "cantina-node", "cantina-pool",
                "cantina-hans-solo", "cantina-collector",
                "cantina-watchdog", "cantina-sentinel", "cantina-dashboard"]
    out = subprocess.check_output(
        ["sudo", "-n", "docker", "ps", "--format", "{{.Names}}\t{{.Status}}"],
        text=True, timeout=8,
    )
    running = {l.split("\t")[0]: l.split("\t")[1] for l in out.splitlines() if "\t" in l}
    missing = [n for n in expected if n not in running]
    unhealthy = [n for n in expected if n in running and "unhealthy" in running[n].lower()]
    if missing or unhealthy:
        return False, f"missing={missing} unhealthy={unhealthy}"
    return True, f"all {len(expected)} containers running"


@check("no Sentry P1 alerts in last 10 min")
def chk_sentry():
    try:
        with open("/var/log/dagtech-sentry/lane1.jsonl") as f:
            lines = f.readlines()[-1000:]
        cutoff = time.time() - 600
        for l in lines:
            try:
                r = json.loads(l)
                ts = time.mktime(time.strptime(r["ts"], "%Y-%m-%dT%H:%M:%SZ"))
                if ts >= cutoff and r.get("severity") == "P1":
                    return False, "P1 alert " + r.get("kind", "?")
            except Exception:
                continue
        return True, "clean 10m window"
    except FileNotFoundError:
        return False, "sentry log not found"


def run_gate():
    log("=== cutover gate start ===")
    all_pass = True
    for name, fn in CHECKS:
        ok, detail = fn()
        sym = "OK" if ok else "FAIL"
        log(f"  [{sym}] {name} — {detail[:120]}")
        if not ok:
            all_pass = False
    return all_pass


def cutover_action(dry):
    if dry:
        log("DRY: would PUT X100 /mcb/pools slot 0 to " + CANDIDATE_POOL_URL)
        log("DRY: would PUT X100 /mcb/restart")
        return True
    log("live cutover starting")
    jwt = x100_jwt()
    pools = x100_get_pools(jwt)
    log("current pools: " + json.dumps(pools))
    new_pools = list(pools) if isinstance(pools, list) else pools
    # Mutate slot 0 url; preserve user/pass + slot 1 blank per "ONE pool only"
    if isinstance(new_pools, list) and new_pools:
        new_pools[0]["url"] = CANDIDATE_POOL_URL
        if len(new_pools) > 1:
            new_pools[1]["url"] = ""
            new_pools[1]["user"] = ""
            new_pools[1]["pass"] = ""
    log("PUT pools body: " + json.dumps(new_pools))
    x100_put_pools(jwt, new_pools)
    time.sleep(2)
    x100_restart(jwt)
    log("PUT /mcb/restart issued")
    return True


def watch_recovery(deadline_share=90, deadline_hashrate=180):
    log("watching recovery, " + str(deadline_share) + "s for first share, " +
        str(deadline_hashrate) + "s for hashrate")
    start = time.time()
    first_share = None
    while time.time() - start < deadline_hashrate:
        raw = cgminer_cmd("devs")
        # crude: Accepted count delta from start
        import re
        m_acc = re.search(r"Accepted=(\d+)", raw)
        m_mhs = re.search(r"MHS 20s=([0-9.]+)", raw)
        mhs = float(m_mhs.group(1)) if m_mhs else 0.0
        log(f"  +{int(time.time()-start)}s  Accepted={m_acc.group(1) if m_acc else '?'}  MHS_20s={mhs}")
        if first_share is None and m_acc:
            first_share = int(m_acc.group(1))
        if time.time() - start > deadline_share and m_acc:
            # would need an external delta tracker; for now just check >0 hashrate
            pass
        if mhs >= 200:
            log("hashrate recovered to " + str(mhs) + " MH/s — pass")
            return True
        time.sleep(10)
    log("hashrate did NOT recover within window")
    return False


def rollback():
    log("ROLLBACK: PUT X100 pool slot 0 back to " + PROD_POOL_URL)
    jwt = x100_jwt()
    pools = x100_get_pools(jwt)
    if isinstance(pools, list) and pools:
        pools[0]["url"] = PROD_POOL_URL
    x100_put_pools(jwt, pools)
    x100_restart(jwt)
    telegram("JARVIS cantina cutover ROLLED BACK — X100 restored to production hans-solo")


def main():
    p = argparse.ArgumentParser()
    p.add_argument("--confirm", action="store_true",
                   help="Actually do the cutover; without this, dry-run only")
    args = p.parse_args()

    telegram("JARVIS cantina cutover starting — dry=" + str(not args.confirm))
    if not run_gate():
        log("GATE FAILED — aborting, no cutover")
        telegram("JARVIS cantina cutover ABORTED at health gate")
        return 2

    log("gate passed; executing cutover " + ("LIVE" if args.confirm else "DRY"))
    if not cutover_action(dry=not args.confirm):
        telegram("JARVIS cantina cutover ABORTED at action")
        return 2

    if not args.confirm:
        log("dry run complete; re-run with --confirm to execute")
        telegram("JARVIS cantina cutover dry run passed. Re-run with --confirm to go live.")
        return 0

    # Live: watch recovery
    if not watch_recovery():
        rollback()
        return 3

    telegram("JARVIS cantina cutover COMPLETE — X100 mining on candidate, BENCH_PHASE moved to post")
    log("cutover complete")
    return 0


if __name__ == "__main__":
    sys.exit(main())
