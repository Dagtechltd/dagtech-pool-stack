# /etc/dagtech-credit-rebalancer.env — copy + edit for YOUR pool
# Find your pool-net via: docker network ls | grep pool-net
POOL_NETWORK=blockdag-pool-release-20260510-152225_pool-net
# Find your PG_URL via: docker inspect asic-pool --format '{{range .Config.Env}}{{println .}}{{end}}' | grep PG_URL
PG_URL=postgres://bdag_pool:CHANGEME@pool-db:5432/pool
REBALANCE_INTERVAL_SECONDS=30
LOG_LEVEL=INFO
